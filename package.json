{
  "name": "react-a11y-test",
  "version": "1.0.0",
  "description": "A React-based Single Page Application (SPA) built with GOV.UK and MoJ Design Systems to demonstrate accessibility and performance best practices.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "analyze": "npm run build && npx vite-bundle-analyzer dist/assets/*.js",
    "a11y": "axe-core playwright test --grep @a11y",
    "lighthouse": "lighthouse http://localhost:3000 --output html --output-path ./lighthouse-report.html",
    "lighthouse:ci": "lhci autorun",
    "server:example": "node server-example.js",
    "monitor:dev": "npm run dev & npm run server:example",
    "performance:test": "npm run build && npm run preview & sleep 5 && npm run lighthouse:ci",
    "docker:build": "docker build -t react-a11y-test .",
    "docker:up": "docker-compose up",
    "docker:run": "docker run -p 3000:3000 react-a11y-test",
    "docker:dev": "docker-compose --profile dev up",
    "docker:prod": "docker-compose up",
    "docker:stop": "docker-compose down"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@ministryofjustice/frontend": "7.1.1",
    "clsx": "2.1.1",
    "cors": "2.8.5",
    "express": "5.2.1",
    "govuk-frontend": "5.13.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "7.68.0",
    "react-router-dom": "7.10.1",
    "react-window": "2.2.3",
    "react-window-infinite-loader": "2.0.0",
    "web-vitals": "5.1.0",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@axe-core/react": "4.11.0",
    "@eslint/js": "9.39.2",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.57.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.1",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "@vitejs/plugin-react": "5.1.2",
    "@vitest/coverage-v8": "4.0.16",
    "@vitest/ui": "4.0.16",
    "autoprefixer": "10.4.23",
    "axe-core": "4.11.0",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "jsdom": "27.3.0",
    "lighthouse": "13.0.1",
    "playwright": "1.57.0",
    "postcss": "8.5.6",
    "sass": "1.97.3",
    "typescript": "5.9.3",
    "vite": "7.3.0",
    "vite-bundle-analyzer": "1.3.2",
    "vitest": "4.0.16",
    "wait-on": "9.0.3"
  },
  "overrides": {
    "tmp": "0.2.4"
  },
  "engines": {
    "node": "24.11.1",
    "npm": "11.7.0"
  },
  "keywords": [
    "react",
    "accessibility",
    "performance",
    "govuk",
    "moj",
    "design-system",
    "typescript",
    "vite"
  ],
  "author": "Matt Hobbs",
  "license": "MIT"
}
